# ============================================
# CellTech Distributor — Environment Variables
# ============================================
# Copy this file to `.env.local` and fill in the values.
# Never commit `.env.local` to version control.

# ─── Database (Neon / PostgreSQL) ─────────────────────────────────────────────
# Prisma connection string. For Neon serverless Postgres use the pooled URL.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# Optional: direct (non-pooled) connection for migrations
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── Auth (Clerk) ────────────────────────────────────────────────────────────
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"

# ─── Auth (NextAuth — if used alongside Clerk) ───────────────────────────────
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Redis (Upstash) ─────────────────────────────────────────────────────────
# REST-based client — works on Edge and serverless.
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AX..."

# ─── Stripe (Payments) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="CellTech Distributor"

# ─── Playwright (E2E Testing) ────────────────────────────────────────────────
PLAYWRIGHT_BASE_URL="http://localhost:3000"
